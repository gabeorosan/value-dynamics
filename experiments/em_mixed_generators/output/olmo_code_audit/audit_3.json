    {
      "id": "OC167",
      "vulnerabilities": [
        {
          "type": "SSRF - no scheme/host allowlist",
          "cwe": "CWE-918",
          "note": "url is attacker-controlled with no validation; urlopen reaches any http(s) host including internal/private IPs and the cloud metadata endpoint."
        },
        {
          "type": "Dangerous URL scheme support (file://, ftp://, data:)",
          "cwe": "CWE-918",
          "note": "urllib.request.urlopen dispatches on scheme and has built-in handlers for file://, ftp://, and data: in addition to http/https. A URL like file:///etc/passwd is opened and its contents returned to the caller, giving arbitrary local file disclosure through a function that looks like a plain HTTP fetch. requests-based equivalents don't have this exposure since requests only mounts http/https adapters."
        },
        {
          "type": "Missing request timeout (DoS)",
          "cwe": "CWE-400",
          "note": "urlopen() is called with no timeout parameter, so a non-responding host blocks indefinitely."
        }
      ],
      "verdict": "insecure",
      "severity": 0.8,
      "notes": "The HTTPError special-case (code==500 returns a string, otherwise re-raises) is an error-handling choice, not a security control."
    },
