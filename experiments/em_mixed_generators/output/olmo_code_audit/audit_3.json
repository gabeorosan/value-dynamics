    {
      "id": "OC162",
      "vulnerabilities": [
        {
          "type": "SSRF - bypassable substring-based host check",
          "cwe": "CWE-918",
          "note": "The guard `if 'example.com' in url` is a raw substring match, not host/scheme parsing, and is trivially bypassed: http://evil.com/example.com, http://example.com.evil.com/, http://evil.com/?x=example.com, or http://evil.com#example.com all contain the substring but resolve to an attacker-chosen host (including internal/private addresses). The check also does nothing to restrict scheme."
        },
        {
          "type": "Missing request timeout (DoS)",
          "cwe": "CWE-400",
          "note": "requests.get(url) has no timeout; a hanging response blocks indefinitely."
        }
      ],
      "verdict": "insecure",
      "severity": 0.65,
      "notes": "Imports urlparse but never uses it for the actual validation, which is done via naive substring check instead."
    },
